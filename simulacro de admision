<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Física — Simulacro</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,400&family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.10/dist/katex.min.css">
<script src="https://cdn.jsdelivr.net/npm/katex@0.16.10/dist/katex.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/katex@0.16.10/dist/contrib/auto-render.min.js"></script>
<style>
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
:root{
  --bg:#0D0D0B;--surface:#1A1A16;--s2:#222218;--border:#2E2E26;--border2:#3D3D30;
  --text:#F2EDD7;--text2:#C9C1A4;--muted:#8A8268;--gold:#C9A84C;--gold2:#E8C96B;
  --gold3:#8B6914;--cream:#F2EDD7;--green:#1D4032;--green2:#2A5C47;--green3:#3D7A5F;
  --ok2:#5AAF87;--err:#C04040;--warn:#C9A84C;--base:4.5vw;
}
html,body{width:100%;background:var(--bg);color:var(--text);font-family:'EB Garamond',Georgia,serif;font-size:var(--base);-webkit-font-smoothing:antialiased;overflow-x:hidden;}
.screen{display:none;width:100%;background:var(--bg);}
.screen.active{display:block;}
#screen-register{padding-bottom:10vw;background-image:radial-gradient(ellipse 80% 40% at 50% 0%,rgba(201,168,76,.07) 0%,transparent 60%);}
.reg-topbar{display:flex;align-items:center;gap:2.5vw;padding:4vw 5vw 3.5vw;border-bottom:1px solid var(--border);background:rgba(13,13,11,.92);}
.reg-brand{font-family:'Cormorant Garamond',serif;font-size:2.8vw;letter-spacing:.35em;text-transform:uppercase;color:var(--gold);}
.reg-dot{width:2px;height:2px;background:var(--gold3);border-radius:50%;}
.reg-brand-sub{font-size:2.8vw;color:var(--muted);font-family:'DM Mono',monospace;}
.reg-hero{padding:7vw 5vw 6vw;border-bottom:1px solid var(--border);}
.reg-h1{font-family:'Cormorant Garamond',serif;font-weight:300;font-size:14vw;line-height:1.02;letter-spacing:-.01em;color:var(--cream);margin-bottom:2vw;}
.reg-h1 em{font-style:italic;color:var(--gold2);}
.reg-sub{font-size:3.8vw;color:var(--muted);line-height:1.55;font-style:italic;margin-bottom:4vw;}
.reg-sub strong{color:var(--text2);font-style:normal;}
.pills-row{display:flex;gap:2vw;flex-wrap:wrap;}
.pill{padding:1.5vw 3.5vw;border-radius:999px;border:1px solid var(--border);font-size:3vw;color:var(--muted);font-family:'DM Mono',monospace;display:flex;align-items:center;gap:1.5vw;}
.pill-dot{width:1.2vw;height:1.2vw;background:var(--gold3);border-radius:50%;}
.reg-form{padding:6vw 5vw 0;}
.field{margin-bottom:4vw;}
.field label{display:block;font-size:3vw;font-weight:400;letter-spacing:.2em;text-transform:uppercase;color:var(--gold);margin-bottom:2vw;font-family:'Cormorant Garamond',serif;}
.field input{width:100%;padding:4vw 4.5vw;background:var(--s2);border:1px solid var(--border);border-bottom:2px solid var(--border2);border-radius:2px;color:var(--text);font-family:'EB Garamond',serif;font-size:4.5vw;outline:none;-webkit-appearance:none;transition:border-color .2s;}
.field input:focus{border-bottom-color:var(--gold);}
.field-row{display:grid;grid-template-columns:1fr 1fr;gap:3vw;}
.area-label{font-size:3vw;letter-spacing:.2em;text-transform:uppercase;color:var(--gold);margin-bottom:3vw;margin-top:2vw;font-family:'Cormorant Garamond',serif;}
.areas-list{display:flex;flex-direction:column;gap:2.5vw;margin-bottom:6vw;}
.area-card{display:flex;align-items:center;gap:4vw;padding:4.5vw 5vw;border:1px solid var(--border);border-radius:2px;cursor:pointer;background:var(--s2);transition:border-color .15s,background .15s;min-height:18vw;}
.area-card.selected{border-color:var(--gold);background:rgba(201,168,76,.07);}
.area-card:active{background:rgba(201,168,76,.05);}
.ac-radio{width:5.5vw;height:5.5vw;border-radius:50%;border:2px solid var(--border2);display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:border-color .15s;}
.area-card.selected .ac-radio{border-color:var(--gold);}
.ac-radio-dot{width:2.2vw;height:2.2vw;border-radius:50%;background:var(--gold);transform:scale(0);transition:transform .15s;}
.area-card.selected .ac-radio-dot{transform:scale(1);}
.ac-icon{font-size:7vw;flex-shrink:0;line-height:1;}
.ac-info{flex:1;}
.ac-name{font-size:4.8vw;font-weight:600;color:var(--text);font-family:'Cormorant Garamond',serif;margin-bottom:0.8vw;}
.ac-sub{font-size:3.2vw;color:var(--muted);line-height:1.3;}
.btn-start{width:100%;padding:5vw;background:transparent;border:1px solid var(--gold3);border-radius:2px;color:var(--gold);font-family:'Cormorant Garamond',serif;font-weight:600;font-size:4vw;letter-spacing:.18em;text-transform:uppercase;cursor:pointer;transition:all .22s;opacity:.25;pointer-events:none;}
.btn-start.ready{opacity:1;pointer-events:all;}
.btn-start.ready:active{background:var(--gold);color:var(--bg);}
#screen-exam{display:none;}
#screen-exam.active{display:block;padding-bottom:20vw;}
.top-bar{position:sticky;top:0;z-index:100;background:rgba(13,13,11,.98);border-bottom:1px solid var(--border);padding:3vw 4.5vw 2.5vw;}
.bar-r1{display:flex;align-items:center;justify-content:space-between;margin-bottom:2.5vw;}
.bar-name{font-family:'DM Mono',monospace;font-size:3vw;color:var(--muted);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:60%;}
.bar-name strong{color:var(--gold);}
.bar-scores{display:flex;gap:3vw;}
.s-ok{font-family:'DM Mono',monospace;font-size:3.2vw;color:var(--ok2);}
.s-err{font-family:'DM Mono',monospace;font-size:3.2vw;color:var(--err);}
.bar-r2{display:flex;align-items:center;gap:2.5vw;}
.bar-qnum{font-family:'DM Mono',monospace;font-size:3vw;color:var(--muted);white-space:nowrap;min-width:10vw;}
.prog-track{flex:1;height:2px;background:var(--border);border-radius:999px;overflow:hidden;}
.prog-fill{height:100%;width:0%;background:linear-gradient(90deg,var(--gold3),var(--gold));border-radius:999px;transition:width .35s ease;}
.bar-pct{font-family:'DM Mono',monospace;font-size:2.8vw;color:var(--muted);min-width:7vw;text-align:right;}
.stage{padding:4vw 4.5vw;}
.timer-row{display:flex;align-items:center;gap:3.5vw;padding:3.5vw 4vw;background:var(--surface);border:1px solid var(--border);border-radius:2px;margin-bottom:3.5vw;}
.timer-ring{position:relative;width:14vw;height:14vw;flex-shrink:0;}
.timer-ring svg{transform:rotate(-90deg);width:100%;height:100%;}
.ring-bg{stroke:var(--border);fill:none;stroke-width:2.5;}
.ring-bar{fill:none;stroke-width:2.5;stroke-linecap:round;stroke-dasharray:125.6;stroke-dashoffset:0;transition:stroke-dashoffset .9s linear,stroke .5s;}
.ring-txt{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-family:'DM Mono',monospace;font-weight:500;font-size:3.8vw;color:var(--text);}
.tr-ok .ring-bar{stroke:var(--gold);}
.tr-mid .ring-bar{stroke:var(--warn);}
.tr-low .ring-bar{stroke:var(--err);}
@keyframes pulse{0%,100%{opacity:1;}50%{opacity:.2;}}
.tr-low .ring-txt{color:var(--err);animation:pulse 1s infinite;}
.timer-meta{flex:1;}
.timer-strong{font-size:4vw;color:var(--text2);display:block;margin-bottom:0.8vw;font-family:'EB Garamond',serif;font-weight:600;}
.timer-sub{font-size:3.2vw;color:var(--muted);font-style:italic;}
.q-card{background:var(--surface);border:1px solid var(--border);border-radius:2px;padding:5vw 4.5vw;position:relative;overflow:hidden;margin-bottom:3vw;}
.q-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;border-radius:2px 2px 0 0;}
.q-card.T::before{background:linear-gradient(90deg,var(--gold3),var(--gold));}
.q-card.F::before{background:linear-gradient(90deg,var(--green),var(--green3));}
.q-card.U::before{background:linear-gradient(90deg,var(--gold3),#B8860B);}
.q-card.C::before{background:linear-gradient(90deg,var(--green),var(--green2));}
.q-card.c-ok{border-color:rgba(90,175,135,.4);}
.q-card.c-err{border-color:rgba(192,64,64,.4);}
@keyframes shake{0%,100%{transform:translateX(0);}25%{transform:translateX(-3px);}75%{transform:translateX(3px);}}
.c-err{animation:shake .25s ease;}
.q-meta{display:flex;align-items:center;gap:2vw;margin-bottom:3.5vw;}
.q-badge{padding:0.8vw 3vw;border-radius:2px;font-size:2.5vw;letter-spacing:.14em;text-transform:uppercase;font-family:'Cormorant Garamond',serif;border:1px solid;}
.T .q-badge{color:var(--gold);border-color:rgba(201,168,76,.3);background:rgba(201,168,76,.06);}
.F .q-badge{color:var(--ok2);border-color:rgba(61,122,95,.3);background:rgba(61,122,95,.06);}
.U .q-badge{color:var(--gold2);border-color:rgba(139,105,20,.3);background:rgba(139,105,20,.06);}
.C .q-badge{color:var(--green3);border-color:rgba(29,64,50,.4);background:rgba(29,64,50,.1);}
.q-tema{font-size:3.2vw;color:var(--muted);font-style:italic;}
.q-text{font-size:4.8vw;line-height:1.65;color:var(--text);margin-bottom:5vw;font-family:'EB Garamond',serif;}
.opt.opt-display{align-items:center;min-height:16vw;}
.opt.opt-display .opt-tx{display:flex;align-items:center;}
.opt-tx .katex-display{margin:0;}
.opt-tx .katex{font-size:1em !important;}
.katex{font-size:1em !important;}
.katex .frac-line{border-bottom-width:0.08em;}
.q-text .katex{font-size:1.05em !important;}
.options{display:flex;flex-direction:column;gap:2.5vw;}
.opt{display:flex;align-items:flex-start;gap:3.5vw;padding:3.8vw 4vw;border:1px solid var(--border);border-radius:2px;cursor:pointer;background:var(--s2);transition:all .14s;user-select:none;min-height:13vw;}
.opt:active:not(.dis){background:rgba(201,168,76,.06);border-color:var(--gold3);}
.opt-lt{font-family:'Cormorant Garamond',serif;font-size:3.8vw;font-weight:700;min-width:5vw;padding-top:0.5vw;color:var(--muted);flex-shrink:0;}
.opt-tx{font-size:4.2vw;line-height:1.55;color:var(--text);font-family:'EB Garamond',serif;}
.opt-tx.is-formula{font-family:'DM Mono',monospace;font-size:3.8vw;color:var(--text2);}
.opt.c-ok{background:rgba(61,122,95,.1);border-color:rgba(90,175,135,.45);}
.opt.c-ok .opt-lt{color:var(--ok2);}
.opt.c-err{background:rgba(192,64,64,.08);border-color:rgba(192,64,64,.45);}
.opt.c-err .opt-lt{color:var(--err);}
.opt.dis{cursor:default;pointer-events:none;}
.tip-box{display:none;margin-top:3.5vw;padding:3.5vw 4vw;border-radius:2px;border-left:3px solid;font-size:3.8vw;line-height:1.65;color:var(--text2);background:rgba(13,13,11,.6);font-style:italic;}
.tip-box.show{display:block;}
@keyframes fadeUp{from{opacity:0;transform:translateY(6px);}to{opacity:1;transform:translateY(0);}}
.tip-box.show{animation:fadeUp .22s ease;}
.T .tip-box{border-color:var(--gold);}
.F .tip-box{border-color:var(--ok2);}
.U .tip-box{border-color:var(--gold3);}
.C .tip-box{border-color:var(--green3);}
.c-ok .tip-box{border-color:var(--ok2) !important;}
.c-err .tip-box{border-color:var(--err) !important;}
.tip-lbl{font-family:'Cormorant Garamond',serif;font-size:2.8vw;font-weight:700;letter-spacing:.2em;text-transform:uppercase;margin-bottom:1.5vw;font-style:normal;}
.c-ok .tip-lbl{color:var(--ok2);}
.c-err .tip-lbl{color:var(--err);}
.to-badge{display:none;margin-top:3vw;padding:3vw 3.5vw;border-radius:2px;background:rgba(192,64,64,.08);border:1px solid rgba(192,64,64,.25);font-size:3.5vw;color:var(--err);text-align:center;font-style:italic;}
.to-badge.show{display:block;}
.bottom-nav{position:sticky;bottom:0;z-index:100;background:rgba(13,13,11,.98);border-top:1px solid var(--border);padding:3.5vw 4.5vw;display:flex;align-items:center;justify-content:space-between;min-height:16vw;}
.result-stamp{font-family:'Cormorant Garamond',serif;font-size:4vw;font-weight:600;letter-spacing:.03em;}
.rs-ok{color:var(--ok2);}
.rs-err{color:var(--err);}
.rs-to{color:var(--warn);}
.btn-next{display:none;align-items:center;gap:2vw;padding:3.5vw 7vw;border:1px solid var(--gold3);border-radius:2px;cursor:pointer;background:transparent;color:var(--gold);font-family:'Cormorant Garamond',serif;font-weight:600;font-size:3.8vw;letter-spacing:.12em;text-transform:uppercase;min-height:13vw;}
.btn-next.show{display:flex;}
.btn-next:active{background:var(--gold);color:var(--bg);}
#screen-results{background:#0e0e10;padding-bottom:12vw;}
.r-topbar{padding:6vw 5vw 5vw;border-bottom:1px solid #2a2a35;background:rgba(14,14,16,.98);position:sticky;top:0;z-index:10;}
.r-title{font-family:'Cormorant Garamond',serif;font-weight:300;font-size:8vw;color:#f2edd7;margin-bottom:1vw;}
.r-student{font-size:3.2vw;color:#6b7280;font-style:italic;}
.r-student strong{color:#c9a84c;font-style:normal;}
.r-body{padding:5vw 4.5vw 0;}
.r-score-hero{background:#13131a;border:1px solid #2a2a35;border-radius:3vw;padding:6vw 5vw;margin-bottom:4vw;display:flex;align-items:center;gap:5vw;}
.big-score{font-family:'Cormorant Garamond',serif;font-weight:300;font-size:22vw;line-height:1;letter-spacing:-.03em;flex-shrink:0;}
.bg-great{color:#22c55e;}
.bg-mid{color:#f59e0b;}
.bg-low{color:#ef4444;}
.score-right{flex:1;}
.score-label{font-size:2.5vw;color:#4b5563;letter-spacing:.15em;text-transform:uppercase;font-family:'Cormorant Garamond',serif;margin-bottom:1.5vw;}
.score-detail{font-size:3.5vw;color:#9ca3af;font-style:italic;margin-bottom:2.5vw;line-height:1.4;}
.score-bar-track{width:100%;height:1.2vw;background:#1e1e28;border-radius:999px;overflow:hidden;}
.score-bar-fill{height:100%;border-radius:999px;width:0%;transition:width 1s ease .3s;}
.r-msg{font-size:3.8vw;border:1px solid #2a2a35;border-left:3px solid #3d3d30;border-radius:1vw;padding:4vw 4.5vw;margin-bottom:4vw;line-height:1.65;color:#9ca3af;font-style:italic;background:#13131a;}
.r-stats-row{display:grid;grid-template-columns:repeat(3,1fr);gap:2.5vw;margin-bottom:4vw;}
.r-stat-box{background:#13131a;border:1px solid #2a2a35;border-radius:2.5vw;padding:5vw 2vw 4vw;text-align:center;}
.r-stat-num{font-family:'Cormorant Garamond',serif;font-size:10vw;font-weight:300;line-height:1;margin-bottom:1vw;}
.r-stat-lbl{font-size:2.5vw;color:#4b5563;letter-spacing:.1em;text-transform:uppercase;font-family:'Cormorant Garamond',serif;}
.r-stat-green .r-stat-num{color:#22c55e;}
.r-stat-red .r-stat-num{color:#ef4444;}
.r-stat-yellow .r-stat-num{color:#f59e0b;}
.r-highlights{display:grid;grid-template-columns:1fr 1fr;gap:2.5vw;margin-bottom:4vw;}
.r-hl-box{background:#13131a;border:1px solid #2a2a35;border-radius:2.5vw;padding:4vw 4.5vw;}
.r-hl-tag{font-size:2.8vw;font-weight:700;letter-spacing:.06em;margin-bottom:2vw;display:flex;align-items:center;gap:1.5vw;}
.r-hl-tag.up{color:#22c55e;}
.r-hl-tag.dn{color:#ef4444;}
.r-hl-lbl{font-size:2.5vw;color:#6b7280;text-transform:uppercase;letter-spacing:.1em;font-family:'Cormorant Garamond',serif;margin-bottom:1vw;}
.r-hl-tema{font-size:3.8vw;color:#e5e7eb;font-style:italic;margin-bottom:1.5vw;font-family:'EB Garamond',serif;line-height:1.3;}
.r-hl-score{font-size:2.8vw;color:#6b7280;font-family:'DM Mono',monospace;}
.r-breakdown-box{background:#13131a;border:1px solid #2a2a35;border-radius:2.5vw;padding:5vw 4.5vw 3vw;margin-bottom:5vw;}
.r-breakdown-title{font-family:'Cormorant Garamond',serif;font-size:2.8vw;font-weight:600;color:#4b5563;letter-spacing:.2em;text-transform:uppercase;margin-bottom:4vw;}
.bd-row{display:flex;align-items:center;gap:2.5vw;margin-bottom:3vw;}
.bd-lbl{font-size:3.2vw;color:#9ca3af;min-width:30vw;font-style:italic;font-family:'EB Garamond',serif;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.bd-track{flex:1;height:1.2vw;background:#1e1e28;border-radius:999px;overflow:hidden;}
.bd-bar{height:100%;border-radius:999px;}
.bd-sc{font-family:'DM Mono',monospace;font-size:2.8vw;color:#6b7280;min-width:8vw;text-align:right;}
.sheets-status{margin-bottom:4vw;padding:3vw 4vw;border-radius:2vw;font-size:3.5vw;font-family:'EB Garamond',serif;font-style:italic;text-align:center;}
.sheets-ok{background:rgba(34,197,94,.08);border:1px solid rgba(34,197,94,.25);color:#22c55e;}
.sheets-err{background:rgba(239,68,68,.06);border:1px solid rgba(239,68,68,.2);color:#ef4444;}
.sheets-saving{background:rgba(245,158,11,.06);border:1px solid rgba(245,158,11,.18);color:#f59e0b;}
.r-actions{display:flex;justify-content:center;}
.btn-retry{display:inline-flex;align-items:center;gap:2.5vw;padding:4.5vw 10vw;border:1px solid #5a4a1c;border-radius:2px;cursor:pointer;background:transparent;color:#c9a84c;font-family:'Cormorant Garamond',serif;font-weight:600;font-size:4vw;letter-spacing:.14em;text-transform:uppercase;min-height:14vw;}
.btn-retry:active{background:#c9a84c;color:#0d0d0b;}
.saving-toast{position:fixed;bottom:5vw;left:50%;transform:translateX(-50%) translateY(4vw);padding:2.5vw 6vw;background:rgba(34,197,94,.12);border:1px solid rgba(34,197,94,.3);border-radius:999px;color:#22c55e;font-size:3.2vw;opacity:0;transition:all .3s;z-index:999;pointer-events:none;white-space:nowrap;}
.saving-toast.show{opacity:1;transform:translateX(-50%) translateY(0);}
@keyframes slideIn{from{opacity:0;transform:translateX(5vw);}to{opacity:1;transform:translateX(0);}}
@keyframes slideOut{from{opacity:1;transform:translateX(0);}to{opacity:0;transform:translateX(-5vw);}}
.q-anim{animation:slideIn .25s ease;}
.q-anim.out{animation:slideOut .16s ease forwards;}
</style>
</head>
<body>

<!-- ══ REGISTER ══ -->
<div class="screen active" id="screen-register">
  <div class="reg-topbar">
    <span class="reg-brand">Física 1</span>
    <div class="reg-dot"></div>
    <span class="reg-brand-sub">Admisión Universitaria</span>
  </div>
  <div class="reg-hero">
    <h1 class="reg-h1">Simulacro<br>de <em>Examen</em></h1>
    <p class="reg-sub"><strong>70 preguntas</strong> · 100 puntos · corrección instantánea con tips</p>
    <div class="pills-row">
      <div class="pill"><div class="pill-dot"></div>30 seg / pregunta</div>
      <div class="pill"><div class="pill-dot"></div>70 preguntas</div>
      <div class="pill"><div class="pill-dot"></div>100 pts</div>
    </div>
  </div>
  <div class="reg-form">
    <div class="field-row">
      <div class="field">
        <label>Nombre</label>
        <input id="inp-n" type="text" placeholder="Ing. David" autocomplete="given-name" oninput="chk()">
      </div>
      <div class="field">
        <label>Apellido</label>
        <input id="inp-a" type="text" placeholder="Samuel" autocomplete="family-name" oninput="chk()">
      </div>
    </div>
    <div class="area-label">Área de postulación</div>
    <div class="areas-list">
      <div class="area-card" onclick="selArea('biomedicas',this)">
        <div class="ac-radio"><div class="ac-radio-dot"></div></div>
        <div class="ac-icon">🧬</div>
        <div class="ac-info"><div class="ac-name">Biomédicas</div><div class="ac-sub">Medicina, Enfermería, Farmacia</div></div>
      </div>
      <div class="area-card" onclick="selArea('ingenierias',this)">
        <div class="ac-radio"><div class="ac-radio-dot"></div></div>
        <div class="ac-icon">⚙️</div>
